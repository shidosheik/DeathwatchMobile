@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (_installAvailable)
            {
                <button class="btn btn-sm btn-outline-light"
                        @onclick="InstallApp">
                    Install App
                </button>
            }
        </div>

        @if (_updateAvailable)
        {
            <div class="alert alert-warning d-flex justify-content-between align-items-center m-2">
                <div>
                    <strong>Update available.</strong> Reload to apply the latest version.
                </div>
                <button class="btn btn-sm btn-dark" @onclick="ApplyUpdate">
                    Reload
                </button>
            </div>
        }

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _installAvailable;
    private IJSObjectReference? _installModule;

    private bool _updateAvailable;
    private IJSObjectReference? _updateModule;

    private DotNetObjectReference<MainLayout>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _selfRef = DotNetObjectReference.Create(this);

        // ---- Install module ----
        _installModule = await JS.InvokeAsync<IJSObjectReference>("import", "./install.js");
        await _installModule.InvokeVoidAsync("initInstallPrompt");

        // Register callbacks (no eval)
        await _installModule.InvokeVoidAsync("registerInstallCallbacks", _selfRef);

        // If install prompt was already captured (rare), show button immediately
        var canInstallNow = await _installModule.InvokeAsync<bool>("canPromptInstall");
        if (canInstallNow)
        {
            _installAvailable = true;
            StateHasChanged();
        }

        // ---- Update module ----
        _updateModule = await JS.InvokeAsync<IJSObjectReference>("import", "./update.js");
        await _updateModule.InvokeVoidAsync("registerUpdateCallbacks", _selfRef);

        var waiting = await _updateModule.InvokeAsync<bool>("initUpdateListener");
        if (waiting)
        {
            _updateAvailable = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void NotifyInstallAvailable()
    {
        _installAvailable = true;
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void NotifyInstalled()
    {
        _installAvailable = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task InstallApp()
    {
        if (_installModule is null) return;

        var accepted = await _installModule.InvokeAsync<bool>("showInstallPrompt");
        if (accepted)
        {
            _installAvailable = false;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public void NotifyUpdateAvailable()
    {
        _updateAvailable = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ApplyUpdate()
    {
        if (_updateModule is null) return;
        await _updateModule.InvokeVoidAsync("activateUpdateAndReload");
    }

    public void Dispose()
    {
        // Unhook DOM listeners in JS modules
        _ = _installModule?.InvokeVoidAsync("unregisterInstallCallbacks");
        _ = _updateModule?.InvokeVoidAsync("unregisterUpdateCallbacks");

        _selfRef?.Dispose();
    }
}