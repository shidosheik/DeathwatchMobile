@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center gap-2">
            <button class="btn btn-sm btn-outline-light" @onclick="InstallApp" disabled="@_installInProgress">
                @(_installInProgress ? "Installing..." : "Install App")
            </button>

            @if (!string.IsNullOrWhiteSpace(_installStatus))
            {
                <span class="small text-muted">@_installStatus</span>
            }
        </div>

        @if (_updateAvailable)
        {
            <div class="alert alert-warning d-flex justify-content-between align-items-center m-2">
                <div>
                    <strong>Update available.</strong> Reload to apply the latest version.
                </div>
                <button class="btn btn-sm btn-dark" @onclick="ApplyUpdate">
                    Reload
                </button>
            </div>
        }

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private IJSObjectReference? _installModule;
    private IJSObjectReference? _updateModule;

    private DotNetObjectReference<MainLayout>? _selfRef;

    private bool _updateAvailable;

    private bool _installInProgress;
    private string? _installStatus;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _selfRef = DotNetObjectReference.Create(this);

        // Use BaseUri so imports work on any route + GitHub Pages base path
        var installJsUrl = new Uri(new Uri(Nav.BaseUri), "install.js").ToString();
        var updateJsUrl  = new Uri(new Uri(Nav.BaseUri), "update.js").ToString();

        // Install module
        _installModule = await JS.InvokeAsync<IJSObjectReference>("import", installJsUrl);

        // Hook the browser event listeners (captures beforeinstallprompt when/if it happens)
        await _installModule.InvokeVoidAsync("initInstallPrompt");
        await _installModule.InvokeVoidAsync("registerInstallCallbacks", _selfRef);

        // Update module (unchanged)
        _updateModule = await JS.InvokeAsync<IJSObjectReference>("import", updateJsUrl);
        await _updateModule.InvokeVoidAsync("registerUpdateCallbacks", _selfRef);

        if (await _updateModule.InvokeAsync<bool>("initUpdateListener"))
        {
            _updateAvailable = true;
            StateHasChanged();
        }
    }

    private async Task InstallApp()
    {
        if (_installModule is null) return;

        _installInProgress = true;
        _installStatus = null;
        StateHasChanged();

        try
        {
            // If Chrome has the install prompt available, this will show it
            // If not available, this returns false
            var accepted = await _installModule.InvokeAsync<bool>("showInstallPrompt");

            if (accepted)
            {
                _installStatus = "Installed (or accepted). If you don’t see it yet, give it a second.";
            }
            else
            {
                // Fallback: always “usable” — guide the user to manual install UX
                _installStatus =
                    "Install prompt not available yet. Try Chrome menu → “Install app” (or the install icon in the address bar). " +
                    "If you just updated, hard-refresh / clear site data and reload.";
            }
        }
        catch (JSException)
        {
            _installStatus =
                "Install prompt failed. Try Chrome menu → “Install app” (or the address bar install icon).";
        }
        finally
        {
            _installInProgress = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void NotifyInstallAvailable()
    {
        // We keep this because it’s still useful for diagnostics,
        // but we’re no longer hiding/showing the button based on it.
        _installStatus = "Install is available.";
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void NotifyInstalled()
    {
        _installStatus = "App installed.";
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void NotifyUpdateAvailable()
    {
        _updateAvailable = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ApplyUpdate()
    {
        if (_updateModule is null) return;
        await _updateModule.InvokeVoidAsync("activateUpdateAndReload");
    }

    public void Dispose()
    {
        _ = _installModule?.InvokeVoidAsync("unregisterInstallCallbacks");
        _ = _updateModule?.InvokeVoidAsync("unregisterUpdateCallbacks");
        _selfRef?.Dispose();
    }
}