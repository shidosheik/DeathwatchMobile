@page "/characters"
@using DeathwatchMobile.Models
@using DeathwatchMobile.Services
@inject DeathwatchMobile.Services.CharacterStore Store
@inject NavigationManager Nav

<PageTitle>Characters</PageTitle>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-0">Characters</h3>
        <div class="text-muted">Your kill-team roster and saved sheets.</div>
    </div>

    <button class="btn btn-primary" @onclick="CreateAndGo">New Character</button>
</div>

@if (_characters is null)
{
    <p class="mt-3">Loading...</p>
}
else if (_characters.Count == 0)
{
    <div class="card p-4 mt-3 text-center">
        <h5>No characters yet</h5>
        <p class="text-muted mb-3">Create your first Deathwatch sheet to get started.</p>
        <div>
            <button class="btn btn-primary" @onclick="CreateAndGo">Create Character</button>
        </div>
    </div>
}
else
{
    <div class="dw-stack">
        @foreach (var c in _characters.OrderByDescending(x => x.UpdatedUtc))
        {
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <div class="fs-5 fw-semibold">@(string.IsNullOrWhiteSpace(c.Name) ? "(Unnamed)" : c.Name)</div>
                        <div class="text-muted small">@DisplayOrDash(c.Chapter) • @DisplayOrDash(c.Specialty) • Rank @c.Rank</div>
                        <div class="text-muted small">Updated @c.UpdatedUtc.ToLocalTime().ToString("g")</div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-sm btn-outline-primary" href="@($"characters/{c.Id}/sheet")">Sheet</a>
                        <a class="btn btn-sm btn-outline-secondary" href="@($"characters/{c.Id}")">Edit</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Character>? _characters;

    protected override async Task OnInitializedAsync()
    {
        _characters = await Store.GetAllAsync();
    }

    private async Task CreateAndGo()
    {
        var c = new Character
        {
            Skills = DefaultSkills.Create()
        };

        await Store.UpsertAsync(c);
        Nav.NavigateTo($"characters/{c.Id}/sheet");
    }

    private static string DisplayOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;
}
