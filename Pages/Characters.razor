@page "/characters"
@using DeathwatchMobile.Models
@using DeathwatchMobile.Services
@inject DeathwatchMobile.Services.CharacterStore Store
@inject NavigationManager Nav

<h3>Characters</h3>

<button class="btn btn-primary" @onclick="CreateAndGo">New Character</button>

@if (_characters is null)
{
    <p class="mt-3">Loading...</p>
}
else if (_characters.Count == 0)
{
    <p class="mt-3">No characters yet.</p>
}
else
{
    <ul class="list-group mt-3">
        @foreach (var c in _characters.OrderByDescending(x => x.UpdatedUtc))
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@(string.IsNullOrWhiteSpace(c.Name) ? "(Unnamed)" : c.Name)</strong>
                    <div class="text-muted small">@c.Chapter • @c.Specialty • Rank @c.Rank</div>
                </div>
                <a class="btn btn-sm btn-outline-secondary" href="/DeathwatchMobile/Characters/@c.Id">Edit</a>
            </li>
        }
    </ul>
}

@code {
    private List<Character>? _characters;

    protected override async Task OnInitializedAsync()
    {
        _characters = await Store.GetAllAsync();
    }

    private async Task CreateAndGo()
    {
        var c = new Character();
        c.Skills = DefaultSkills.Create();
        await Store.UpsertAsync(c);
        Nav.NavigateTo($"/DeathwatchMobile/Characters/{c.Id}");
    }

    
}