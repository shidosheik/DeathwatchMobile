@page "/characters/{Id}"
@using DeathwatchMobile.Models
@inject DeathwatchMobile.Services.CharacterStore Store
@inject DeathwatchMobile.Services.CharacterSkillService CharacterSkillService
@inject DeathwatchMobile.Services.TalentLibraryService TalentLibraryService
@inject NavigationManager Nav

<PageTitle>Edit Character</PageTitle>

@if (_character is null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-0">Edit Character</h3>
            <div class="text-muted">Update the sheet data used by the mobile view.</div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary" href="/DeathwatchMobile/characters">Back</a>
            <a class="btn btn-outline-primary" href="@($"/DeathwatchMobile/characters/{Id}/sheet")">View Sheet</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_saveMessage))
    {
        <div class="alert alert-success">@_saveMessage</div>
    }

    <div class="dw-stack">
        <div class="card p-3">
            <h5 class="mb-3">Identity</h5>

            <div class="mb-3">
                <label class="form-label">Name</label>
                <input class="form-control" @bind="_character.Name" />
            </div>

            <div class="row">
                <div class="col-12 col-md-6 mb-3">
                    <label class="form-label">Chapter</label>
                    <input class="form-control" @bind="_character.Chapter" />
                </div>
                <div class="col-12 col-md-6 mb-3">
                    <label class="form-label">Specialty</label>
                    <input class="form-control" @bind="_character.Specialty" />
                </div>
                <div class="col-12 col-md-6 mb-3">
                    <label class="form-label">Demeanor</label>
                    <input class="form-control" @bind="_character.Demeanor" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <label class="form-label">Rank</label>
                    <input class="form-control" type="number" min="1" max="8" @bind="_character.Rank" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <label class="form-label">Renown</label>
                    <input class="form-control" @bind="_character.Renown" />
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h5 class="mb-3">Characteristics</h5>

            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Stat</th>
                            <th style="width: 110px;">Base</th>
                            <th style="width: 110px;">Assist</th>
                            <th style="width: 110px;">Adv</th>
                            <th style="width: 110px;">Total</th>
                            <th style="width: 110px;">Bonus</th>
                        </tr>
                    </thead>
                    <tbody>
                        @CharRow("WS", _character.WS)
                        @CharRow("BS", _character.BS)
                        @CharRow("S", _character.S)
                        @CharRow("T", _character.T)
                        @CharRow("Ag", _character.Ag)
                        @CharRow("Int", _character.Int)
                        @CharRow("Per", _character.Per)
                        @CharRow("WP", _character.WP)
                        @CharRow("Fel", _character.Fel)
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card p-3">
            <h5 class="mb-3">Trackers & Movement</h5>

            <div class="row">
                <div class="col-12 col-md-6 mb-3">
                    <label class="form-label">Wounds (Current / Max)</label>
                    <div class="d-flex gap-2">
                        <input class="form-control" type="number" min="0" @bind="_character.WoundsCurrent" />
                        <input class="form-control" type="number" min="0" @bind="_character.WoundsMax" />
                    </div>
                </div>

                <div class="col-12 col-md-6 mb-3">
                    <label class="form-label">Fate (Current / Max)</label>
                    <div class="d-flex gap-2">
                        <input class="form-control" type="number" min="0" @bind="_character.FateCurrent" />
                        <input class="form-control" type="number" min="0" @bind="_character.FateMax" />
                    </div>
                </div>

                <div class="col-6 col-md-3 mb-3">
                    <label class="form-label">Half Move</label>
                    <input class="form-control" type="number" min="0" @bind="_character.MoveHalf" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <label class="form-label">Full Move</label>
                    <input class="form-control" type="number" min="0" @bind="_character.MoveFull" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <label class="form-label">Charge</label>
                    <input class="form-control" type="number" min="0" @bind="_character.MoveCharge" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <label class="form-label">Run</label>
                    <input class="form-control" type="number" min="0" @bind="_character.MoveRun" />
                </div>
            </div>
        </div>

        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <h5 class="mb-0">Skills</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-sm btn-outline-primary" @onclick="AddSkill">Add Skill</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ResetSkillFilters">Reset Filters</button>
                </div>
            </div>

            <div class="row g-2 align-items-end mb-3">
                <div class="col-12 col-md-4">
                    <label class="form-label">Search</label>
                    <input class="form-control form-control-sm" placeholder="Awareness, Dodge..."
                           @bind="_skillSearch" @bind:event="oninput" />
                </div>

                <div class="col-6 col-md-3">
                    <label class="form-label">Governing</label>
                    <select class="form-select form-select-sm" @bind="_skillGoverning">
                        <option value="">All</option>
                        <option value="WS">WS</option>
                        <option value="BS">BS</option>
                        <option value="S">S</option>
                        <option value="T">T</option>
                        <option value="Ag">Ag</option>
                        <option value="Int">Int</option>
                        <option value="Per">Per</option>
                        <option value="WP">WP</option>
                        <option value="Fel">Fel</option>
                    </select>
                </div>

                <div class="col-6 col-md-3">
                    <label class="form-label">Sort</label>
                    <select class="form-select form-select-sm" @bind="_skillSort">
                        <option value="name">Name</option>
                        <option value="target">Target</option>
                        <option value="governing">Governing</option>
                        <option value="training">Training</option>
                    </select>
                </div>

                <div class="col-12 col-md-2">
                    <div class="form-check mt-md-4">
                        <input class="form-check-input" type="checkbox" id="trainedOnly" @bind="_trainedOnly" />
                        <label class="form-check-label" for="trainedOnly">Trained only</label>
                    </div>
                </div>
            </div>


            <div class="table-responsive dw-skills-table-wrap">
                <table class="table table-sm align-middle mb-0 dw-skills-table">
                    <thead>
                        <tr>
                            <th>Skill</th>
                            <th style="width:110px;">Gov.</th>
                            <th style="width:160px;">Training</th>
                            <th style="width:110px;">Mod</th>
                            <th style="width:110px;">Target</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in CharacterSkillService.FilterSkills(_character, _skillSearch, _skillGoverning, _skillSort, _trainedOnly))
                        {
                            <tr>
                                <td>
                                    <input class="form-control form-control-sm" @bind="s.Name" />
                                </td>
                                <td>
                                    <select class="form-select form-select-sm" @bind="s.Governing">
                                        <option value="WS">WS</option>
                                        <option value="BS">BS</option>
                                        <option value="S">S</option>
                                        <option value="T">T</option>
                                        <option value="Ag">Ag</option>
                                        <option value="Int">Int</option>
                                        <option value="Per">Per</option>
                                        <option value="WP">WP</option>
                                        <option value="Fel">Fel</option>
                                    </select>
                                </td>
                                <td>
                                    <select class="form-select form-select-sm" @bind="s.Training">
                                        <option value="@SkillTraining.Untrained">Untrained</option>
                                        <option value="@SkillTraining.Trained">Trained</option>
                                        <option value="@SkillTraining.Plus10">+10</option>
                                        <option value="@SkillTraining.Plus20">+20</option>
                                    </select>
                                </td>
                                <td>
                                    <input class="form-control form-control-sm" type="number" @bind="s.MiscMod" />
                                </td>
                                <td>@_character.SkillTarget(s)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="card p-3 h-100">
                    <h5 class="mb-3">Combat Loadout</h5>

                    <div class="mb-3">
                        <label class="form-label">Armor</label>

                        <div class="row g-2">

                            <div class="col-4">
                                <label class="form-label">Head</label>
                                <InputNumber class="form-control" @bind-Value="_character.ArmorHead" />
                            </div>

                            <div class="col-4">
                                <label class="form-label">Left Arm</label>
                                <InputNumber class="form-control" @bind-Value="_character.ArmorLeftArm" />
                            </div>

                            <div class="col-4">
                                <label class="form-label">Right Arm</label>
                                <InputNumber class="form-control" @bind-Value="_character.ArmorRightArm" />
                            </div>

                            <div class="col-4">
                                <label class="form-label">Body</label>
                                <InputNumber class="form-control" @bind-Value="_character.ArmorBody" />
                            </div>

                            <div class="col-4">
                                <label class="form-label">Left Leg</label>
                                <InputNumber class="form-control" @bind-Value="_character.ArmorLeftLeg" />
                            </div>

                            <div class="col-4">
                                <label class="form-label">Right Leg</label>
                                <InputNumber class="form-control" @bind-Value="_character.ArmorRightLeg" />
                            </div>

                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Weapons</label>
                        <textarea class="form-control" rows="4" @bind="_character.Weapons"></textarea>
                    </div>

                    <div class="mb-0">
                        <label class="form-label">Gear</label>
                        <textarea class="form-control" rows="4" @bind="_character.Gear"></textarea>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card p-3 h-100">
                    <h5 class="mb-3">Abilities & Notes</h5>

                    <div class="mb-3">
                        <label class="form-label">Talents & Traits</label>
                        <div class="row g-2 mb-2">
                            <div class="col-12 col-md-5">
                                <input class="form-control form-control-sm"
                                       placeholder="Search talent library..."
                                       @bind="_talentSearch"
                                       @bind:event="oninput" />
                            </div>
                            <div class="col-9 col-md-5">
                                <select class="form-select form-select-sm" @bind="_selectedTalentId">
                                    <option value="">Select a talent...</option>
                                    @foreach (var talent in FilteredTalentLibrary)
                                    {
                                        <option value="@talent.Id">@talent.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-3 col-md-2 d-grid">
                                <button class="btn btn-sm btn-outline-primary" @onclick="AddSelectedTalent">Add</button>
                            </div>
                        </div>
                        <textarea class="form-control" rows="4" @bind="_character.TalentsAndTraits"></textarea>
                        <div class="form-text">Add entries from the talent library, then edit text freely if needed.</div>
                    </div>

                    @if (SelectedLibraryTalents.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">Talents Added from Library</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var talentName in SelectedLibraryTalents)
                                {
                                    <span class="badge bg-secondary d-inline-flex align-items-center gap-1">
                                        @talentName
                                        <button type="button"
                                                class="btn-close btn-close-white btn-sm"
                                                style="font-size: .6rem;"
                                                aria-label="Remove"
                                                @onclick="() => RemoveTalentFromNotes(talentName)">
                                        </button>
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Solo Mode Ability</label>
                        <textarea class="form-control" rows="3" @bind="_character.SoloModeAbility"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Squad Mode Ability</label>
                        <textarea class="form-control" rows="3" @bind="_character.SquadModeAbility"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Chapter Trapping</label>
                        <textarea class="form-control" rows="3" @bind="_character.ChapterTrapping"></textarea>
                    </div>

                    <div class="mb-0">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="4" @bind="_character.Notes"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h5 class="mb-3">Experience</h5>

            <div class="row mb-3">
                <div class="col-4">
                    <div class="card p-2 text-center">
                        <div class="small text-muted">Earned</div>
                        <div class="fs-4">@_character.XpEarned</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card p-2 text-center">
                        <div class="small text-muted">Spent</div>
                        <div class="fs-4">@_character.XpSpent</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card p-2 text-center">
                        <div class="small text-muted">Remaining</div>
                        <div class="fs-4 fw-bold">@_character.XpRemaining</div>
                    </div>
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-4">
                    <input class="form-control form-control-sm" type="number" @bind="_newXpAmount" placeholder="Amount" />
                </div>

                <div class="col-8">
                    <input class="form-control form-control-sm" @bind="_newXpReason" placeholder="Reason" />
                </div>

                <div class="col-12">
                    <button class="btn btn-sm btn-primary" @onclick="AddXpEntry">Add XP Entry</button>
                </div>
            </div>

            @if (_character.XpLog.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in _character.XpLog.OrderByDescending(x => x.Date))
                            {
                                <tr>
                                    <td>@x.Date.ToShortDateString()</td>
                                    <td class="@(x.Amount < 0 ? "text-danger" : "text-success")">@x.Amount</td>
                                    <td>@x.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-success" @onclick="Save">Save</button>
            <button class="btn btn-outline-danger" @onclick="Delete">Delete</button>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    private Character? _character;
    private string _saveMessage = "";
    private List<TalentDefinition> _talentLibrary = new();
    private string _talentSearch = "";
    private string _selectedTalentId = "";

    private IEnumerable<TalentDefinition> FilteredTalentLibrary =>
        TalentLibraryService.FilterTalents(_talentLibrary, _talentSearch);

    private IEnumerable<string> SelectedLibraryTalents =>
        _talentLibrary
            .Select(t => t.Name)
            .Where(IsTalentListedOnSheet)
            .OrderBy(x => x);

    protected override async Task OnInitializedAsync()
    {
        _character = await Store.GetByIdAsync(Id) ?? new Character { Id = Id };
        _character.Skills ??= new List<Skill>();
        _talentLibrary = TalentLibraryService.GetTalents().OrderBy(t => t.Name).ToList();
    }

    private async Task Save()
    {
        if (_character is null) return;

        await Store.UpsertAsync(_character);
        _saveMessage = $"Saved {_character.UpdatedUtc.ToLocalTime():g}";
    }

    private async Task Delete()
    {
        await Store.DeleteAsync(Id);
        Nav.NavigateTo("/DeathwatchMobile/characters");
    }

    private RenderFragment CharRow(string label, StatBlock stat) => __builder =>
    {
        var seq = 0;
        __builder.OpenElement(seq++, "tr");

        __builder.OpenElement(seq++, "td");
        __builder.AddContent(seq++, label);
        __builder.CloseElement();

        void NumberInput(string css, int value, Action<int> setter, string? min = null)
        {
            __builder.OpenElement(seq++, "td");
            __builder.OpenElement(seq++, "input");
            __builder.AddAttribute(seq++, "class", css);
            __builder.AddAttribute(seq++, "type", "number");
            if (!string.IsNullOrWhiteSpace(min))
            {
                __builder.AddAttribute(seq++, "min", min);
            }
            __builder.AddAttribute(seq++, "value", BindConverter.FormatValue(value));
            __builder.AddAttribute(seq++, "onchange", EventCallback.Factory.CreateBinder<int>(this, setter, value));
            __builder.CloseElement();
            __builder.CloseElement();
        }

        NumberInput("form-control form-control-sm", stat.Base, v => stat.Base = v, "0");
        NumberInput("form-control form-control-sm", stat.PowerAssist, v => stat.PowerAssist = v);
        NumberInput("form-control form-control-sm", stat.Advances, v => stat.Advances = v, "0");

        __builder.OpenElement(seq++, "td");
        __builder.AddContent(seq++, stat.Total);
        __builder.CloseElement();

        __builder.OpenElement(seq++, "td");
        __builder.AddContent(seq++, stat.Bonus);
        __builder.CloseElement();

        __builder.CloseElement();
    };

    private void AddSkill()
    {
        _character?.Skills.Add(new Skill
        {
            Name = "New Skill",
            Governing = "Per",
            Training = SkillTraining.Untrained
        });
    }

    private string _skillSearch = "";
    private string _skillGoverning = "";
    private string _skillSort = "name";
    private bool _trainedOnly = false;

    private void ResetSkillFilters()
    {
        _skillSearch = "";
        _skillGoverning = "";
        _skillSort = "name";
        _trainedOnly = false;
    }

    private void AddSelectedTalent()
    {
        if (_character is null || string.IsNullOrWhiteSpace(_selectedTalentId))
        {
            return;
        }

        var selected = _talentLibrary.FirstOrDefault(t => t.Id == _selectedTalentId);
        if (selected is null || IsTalentListedOnSheet(selected.Name))
        {
            return;
        }

        _character.TalentsAndTraits = string.IsNullOrWhiteSpace(_character.TalentsAndTraits)
            ? selected.Name
            : $"{_character.TalentsAndTraits}{Environment.NewLine}{selected.Name}";
    }

    private void RemoveTalentFromNotes(string talentName)
    {
        if (_character is null || string.IsNullOrWhiteSpace(_character.TalentsAndTraits))
        {
            return;
        }

        var updatedLines = _character.TalentsAndTraits
            .Split(Environment.NewLine, StringSplitOptions.None)
            .Where(line => !string.Equals(line.Trim(), talentName, StringComparison.OrdinalIgnoreCase))
            .ToList();

        _character.TalentsAndTraits = string.Join(Environment.NewLine, updatedLines);
    }

    private bool IsTalentListedOnSheet(string talentName)
    {
        if (_character is null || string.IsNullOrWhiteSpace(_character.TalentsAndTraits))
        {
            return false;
        }

        return _character.TalentsAndTraits
            .Split(Environment.NewLine, StringSplitOptions.None)
            .Any(line => string.Equals(line.Trim(), talentName, StringComparison.OrdinalIgnoreCase));
    }

    private int _newXpAmount;
    private string _newXpReason = "";

    private async Task AddXpEntry()
    {
        if (_character == null || _newXpAmount == 0) return;

        _character.XpLog.Add(new XpEntry
        {
            Amount = _newXpAmount,
            Reason = _newXpReason
        });

        _newXpAmount = 0;
        _newXpReason = "";

        await Save();
    }

    private string _lastRollResult = "";
    private readonly Random _rng = new();

    private void RollSkill(Skill s)
    {
        if (_character == null) return;

        var roll = _rng.Next(1, 101);
        var target = _character.SkillTarget(s);
        var margin = Math.Abs(target - roll);
        var degrees = (margin / 10) + 1;
        var success = roll <= target;

        _lastRollResult = $"{s.Name}: rolled {roll} vs {target} → " +
            (success ? $"SUCCESS ({degrees} DoS)" : $"FAILURE ({degrees} DoF)");
    }
}
