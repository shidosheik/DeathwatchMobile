@page "/skills"
@using DeathwatchMobile.Models
@inject DeathwatchMobile.Services.SkillLibraryService SkillLibraryService

<PageTitle>Skills Library</PageTitle>

<div class="container py-3">
    <h3 class="mb-3">Skills Library</h3>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-12">
                    <InputText class="form-control"
                               placeholder="Search skills..."
                               @bind-Value="_searchText"
                               @bind-Value:event="oninput" />
                </div>

                <div class="col-12">
                    <select class="form-select" @bind="_selectedCategory">
                        <option value="">All Categories</option>
                        @foreach (var category in _categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (_filteredSkills.Count == 0)
    {
        <div class="alert alert-secondary">
            No skills found.
        </div>
    }
    else
    {
        <div class="d-grid gap-2">
            @foreach (var skill in _filteredSkills)
            {
                <div class="card shadow-sm skill-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="mb-1">@skill.Name</h5>
                                <div class="text-muted small">
                                    @skill.Characteristic • @skill.Category
                                    @if (skill.IsTrainedOnly)
                                    {
                                        <span> • Trained Only</span>
                                    }
                                </div>
                            </div>

                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => ToggleExpanded(skill.Name)">
                                @(IsExpanded(skill.Name) ? "Hide" : "View")
                            </button>
                        </div>

                        <div class="mb-2">
                            @skill.Summary
                        </div>

                        @if (IsExpanded(skill.Name))
                        {
                            <div class="border-top pt-2 small">
                                @skill.Description
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string _searchText = "";
    private string _selectedCategory = "";
    private HashSet<string> _expanded = new();
    private IReadOnlyList<string> _categories => SkillLibraryService.GetCategories();
    private IReadOnlyList<SkillLibraryEntry> _filteredSkills => SkillLibraryService.FilterSkills(_searchText, _selectedCategory);

    private void ToggleExpanded(string name)
    {
        if (!_expanded.Add(name))
            _expanded.Remove(name);
    }

    private bool IsExpanded(string name) => _expanded.Contains(name);

}
