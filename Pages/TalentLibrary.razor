@page "/talents"

@using DeathwatchMobile.Models
@using DeathwatchMobile.Services

<PageTitle>Talent Library</PageTitle>

<h3 class="mb-3">Talent Library</h3>

<div class="mb-3">
    <input class="form-control"
           placeholder="Search talents..."
           @bind="_searchText" />
</div>

@if (!_filteredTalents.Any())
{
    <div class="text-muted">No talents found.</div>
}
else
{
    <div class="row g-3">
        @foreach (var talent in _filteredTalents)
        {
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-1">@talent.Name</h5>

                        @if (!string.IsNullOrWhiteSpace(talent.Prerequisites))
                        {
                            <div class="small text-muted mb-2">
                                <strong>Prerequisites:</strong> @talent.Prerequisites
                            </div>
                        }

                        <div class="mb-2">
                            @GetPreview(talent.Description)
                        </div>

                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => ToggleExpanded(talent.Id)">
                            @(IsExpanded(talent.Id) ? "Hide" : "View")
                        </button>

                        @if (IsExpanded(talent.Id))
                        {
                            <div class="mt-3 border-top pt-3">
                                <div>@talent.Description</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private string _searchText = string.Empty;
    private List<TalentDefinition> _talents = new();
    private HashSet<string> _expanded = new();

    private IEnumerable<TalentDefinition> _filteredTalents =>
        _talents.Where(t =>
            string.IsNullOrWhiteSpace(_searchText) ||
            t.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            t.Prerequisites.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            t.Description.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        _talents = new TalentLibraryService().GetTalents();
    }

    private void ToggleExpanded(string id)
    {
        if (!_expanded.Add(id))
            _expanded.Remove(id);
    }

    private bool IsExpanded(string id) => _expanded.Contains(id);

    private string GetPreview(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        return text.Length <= 140 ? text : text[..140] + "...";
    }
}